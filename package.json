{
	"name": "my-personal-site",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"engines": {
		"node": ">=24.0.0"
	},
	"scripts": {
		"dev": "vite dev --host 0.0.0.0",
		"build": "vite build",
		"preview": "vite preview",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"prepare": "husky",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:e2e": "playwright test",
		"test:links": "start-server-and-test 'npm run preview -- --port 4173 --strictPort' http://localhost:4173 'linkinator http://localhost:4173'",
		"ci": "npm run lint && npm run check && npm run test && npm run build && npm run test:e2e && npm run test:links"
	},
	"devDependencies": {
		"@axe-core/playwright": "^4.11.3",
		"@playwright/test": "^1.60.0",
		"@sveltejs/adapter-netlify": "^6.0.4",
		"@sveltejs/enhanced-img": "^0.10.4",
		"@sveltejs/kit": "^2.64.0",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tailwindcss/vite": "^4.3.0",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/svelte": "^5.3.1",
		"@testing-library/user-event": "^14.6.1",
		"@trivago/prettier-plugin-sort-imports": "^6.0.2",
		"@types/node": "^25.9.2",
		"@typescript-eslint/eslint-plugin": "^8.13.0",
		"@typescript-eslint/parser": "^8.13.0",
		"@vitest/ui": "^4.1.8",
		"eslint": "^9.14.0",
		"eslint-config-prettier": "^9.1.0",
		"eslint-plugin-svelte": "^2.46.0",
		"globals": "^15.12.0",
		"husky": "^9.1.7",
		"jsdom": "^29.1.1",
		"lint-staged": "^17.0.7",
		"linkinator": "^7.6.1",
		"prettier": "^3.3.3",
		"prettier-plugin-svelte": "^3.2.7",
		"start-server-and-test": "^3.0.8",
		"svelte": "^5.1.16",
		"svelte-check": "^4.0.5",
		"svgo": "^3.3.2",
		"tailwindcss": "^4.3.0",
		"tslib": "^2.8.1",
		"typescript": "^5.6.3",
		"typescript-eslint": "^8.13.0",
		"vite": "^8.0.0",
		"vitest": "^4.1.8"
	},
	"overrides": {
		"cookie": "^0.7.2",
		"esbuild": "^0.25.0"
	},
	"lint-staged": {
		"*.{js,ts,svelte}": [
			"prettier --write",
			"eslint --fix"
		],
		"*.{css,html,json,md}": [
			"prettier --write"
		]
	}
}
