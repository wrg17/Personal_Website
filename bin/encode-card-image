#!/usr/bin/env bash
set -euo pipefail

usage() {
	cat <<'EOF'
Usage: bin/encode-card-image <source> <name>

Generates JPEG and AVIF variants at 480w and 800w in static/img/, sized
and quality-tuned for the project/hobby card slot.

Args:
  source  Path to high-res source image (jpeg, png, heic, etc.)
  name    Base name for outputs (e.g. "ocean" -> ocean-480.jpeg, ocean-800.avif)

Requirements:
  - sips     (built into macOS)
  - avifenc  (brew install libavif)

After running, the script prints a ready-to-paste snippet for
src/lib/data/projects.ts.
EOF
	exit 1
}

[[ $# -eq 2 ]] || usage

src="$1"
name="$2"
out="static/img"

[[ -f "$src" ]] || { echo "Source not found: $src" >&2; exit 1; }
[[ -d "$out" ]] || { echo "Run from repo root (no $out/)" >&2; exit 1; }

command -v sips >/dev/null || { echo "sips not on PATH (expected on macOS)" >&2; exit 1; }
command -v avifenc >/dev/null || { echo "avifenc not on PATH — install with: brew install libavif" >&2; exit 1; }

tmp=$(mktemp -d)
trap 'rm -rf "$tmp"' EXIT

for w in 480 800; do
	sips -Z "$w" --setProperty formatOptions 80 "$src" --out "$out/${name}-${w}.jpeg" >/dev/null
	sips -Z "$w" "$src" --out "$tmp/${name}-${w}.jpeg" >/dev/null
	avifenc -q 60 "$tmp/${name}-${w}.jpeg" "$out/${name}-${w}.avif" >/dev/null
done

echo "Wrote:"
for f in "$out/${name}-480.jpeg" "$out/${name}-800.jpeg" "$out/${name}-480.avif" "$out/${name}-800.avif"; do
	size=$(stat -f '%z' "$f" 2>/dev/null || stat -c '%s' "$f")
	printf '  %7d bytes  %s\n' "$size" "$f"
done

cat <<EOF

Snippet for src/lib/data/projects.ts:

const ${name}Srcset = '/img/${name}-480.jpeg 480w, /img/${name}-800.jpeg 800w';
const ${name}AvifSrcset = '/img/${name}-480.avif 480w, /img/${name}-800.avif 800w';

{
	title: '...',
	image: '/img/${name}-800.jpeg',
	imageSrcset: ${name}Srcset,
	imageAvifSrcset: ${name}AvifSrcset,
	imageAlt: '...',
	description: '...',
	link: '...'
}
EOF
